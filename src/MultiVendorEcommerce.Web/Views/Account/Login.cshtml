@model Web.Models.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign in";
}

<h2 class="mb-1 fw-bold">Welcome back</h2>
<p class="text-muted mb-4">Sign in to keep shopping where you left off.</p>

<form asp-action="Login" method="post">
    <input type="hidden" asp-for="ReturnUrl" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label small fw-semibold"></label>
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
            <input asp-for="Email" type="email" class="form-control border-start-0 ps-0" placeholder="you@example.com" autocomplete="username" />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Password" class="form-label small fw-semibold"></label>
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-lock-fill"></i></span>
            <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" autocomplete="current-password" />
        </div>
        <span asp-validation-for="Password" class="text-danger small"></span>
    </div>

    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label class="form-check-label small" asp-for="RememberMe"></label>
        </div>
        <a class="small text-muted text-decoration-none">Forgot password?</a>
    </div>

    <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-box-arrow-in-right me-1"></i>Sign in</button>
</form>

<div class="text-center my-3 small text-muted">— or —</div>

<div class="d-grid gap-2">
    <a asp-action="Register" class="btn btn-outline-secondary"><i class="bi bi-person-plus me-1"></i>Create a customer account</a>
    <a asp-action="RegisterVendor" class="btn btn-outline-success"><i class="bi bi-shop me-1"></i>Sign up as a vendor</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
