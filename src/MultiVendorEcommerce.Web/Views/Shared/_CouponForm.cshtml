@using Domain.Enums
@model Web.Models.ViewModels.Coupons.CouponFormViewModel

<input type="hidden" asp-for="Id" />
<div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>

<div class="row g-3">
    <div class="col-md-6">
        <label asp-for="Code" class="form-label"></label>
        <input asp-for="Code" class="form-control text-uppercase" readonly="@Model.Id.HasValue" />
        <span asp-validation-for="Code" class="text-danger small"></span>
    </div>
    <div class="col-md-3">
        <label asp-for="DiscountType" class="form-label"></label>
        <select asp-for="DiscountType" class="form-select">
            <option value="@CouponDiscountType.Percentage">Percentage (%)</option>
            <option value="@CouponDiscountType.FixedAmount">Fixed amount</option>
        </select>
    </div>
    <div class="col-md-3">
        <label asp-for="DiscountValue" class="form-label"></label>
        <input asp-for="DiscountValue" class="form-control" type="number" step="0.01" min="0.01" />
        <span asp-validation-for="DiscountValue" class="text-danger small"></span>
    </div>
    <div class="col-md-4">
        <label asp-for="MinimumOrderAmount" class="form-label"></label>
        <input asp-for="MinimumOrderAmount" class="form-control" type="number" step="0.01" min="0" />
    </div>
    <div class="col-md-4">
        <label asp-for="MaxUses" class="form-label"></label>
        <input asp-for="MaxUses" class="form-control" type="number" min="1" />
    </div>
    <div class="col-md-4">
        <label asp-for="MaxUsesPerCustomer" class="form-label"></label>
        <input asp-for="MaxUsesPerCustomer" class="form-control" type="number" min="1" />
    </div>
    <div class="col-md-6">
        <label asp-for="StartsAtUtc" class="form-label"></label>
        <input asp-for="StartsAtUtc" class="form-control" type="datetime-local" />
    </div>
    <div class="col-md-6">
        <label asp-for="ExpiresAtUtc" class="form-label"></label>
        <input asp-for="ExpiresAtUtc" class="form-control" type="datetime-local" />
    </div>
    <div class="col-md-12">
        <div class="form-check">
            <input asp-for="IsActive" class="form-check-input" />
            <label asp-for="IsActive" class="form-check-label"></label>
        </div>
    </div>
</div>
