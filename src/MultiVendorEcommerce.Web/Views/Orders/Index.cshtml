@using Domain.Enums
@model Application.Common.Models.PaginatedList<Application.Orders.Queries.GetMyOrders.MyOrderListItemDto>
@{
    ViewData["Title"] = "My Orders";

    (string css, string label, string icon) StatusChip(OrderStatus s) => s switch
    {
        OrderStatus.Paid           => ("bg-info text-white",          "Paid",           "bi-credit-card"),
        OrderStatus.Processing     => ("bg-primary text-white",       "Processing",     "bi-tools"),
        OrderStatus.Shipped        => ("bg-warning text-dark",        "Shipped",        "bi-truck"),
        OrderStatus.Delivered      => ("bg-success text-white",       "Delivered",      "bi-check2-circle"),
        OrderStatus.Cancelled      => ("bg-danger text-white",        "Cancelled",      "bi-x-circle"),
        OrderStatus.Refunded       => ("bg-secondary text-white",     "Refunded",       "bi-arrow-counterclockwise"),
        OrderStatus.PendingPayment => ("bg-light text-dark border",   "Pending payment","bi-hourglass-split"),
        _                          => ("bg-light text-dark border",   s.ToString(),     "bi-circle")
    };
}

<div class="mv-section-head mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-bag me-2"></i>My Orders</h2>
        <small class="text-muted">@Model.TotalCount order@(Model.TotalCount == 1 ? "" : "s") · sorted newest first</small>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="card mv-card">
        <div class="card-body text-center py-5">
            <i class="bi bi-bag-x display-3 d-block mb-3 text-muted"></i>
            <h5>No orders yet</h5>
            <p class="text-muted">Once you place your first order, it'll appear here.</p>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary mt-2"><i class="bi bi-grid-3x3-gap me-1"></i>Start shopping</a>
        </div>
    </div>
}
else
{
    @foreach (var o in Model.Items)
    {
        var (badgeCss, badgeLabel, badgeIcon) = StatusChip(o.Status);
        <div class="card mv-card mb-3">
            <div class="card-body">
                <div class="row g-3 align-items-center">
                    <div class="col-md-1 col-3 text-center">
                        <div class="mv-cat-icon mx-auto" style="width:48px;height:48px;font-size:1.2rem;"><i class="bi bi-receipt"></i></div>
                    </div>
                    <div class="col-md-4 col-9">
                        <div class="text-muted small text-uppercase">Order</div>
                        <div class="fw-semibold"><code>@o.OrderNumber</code></div>
                        <small class="text-muted"><i class="bi bi-clock me-1"></i>@o.PlacedAtUtc.ToString("MMM d, yyyy · HH:mm")</small>
                    </div>
                    <div class="col-md-2 col-4">
                        <div class="text-muted small text-uppercase">Items</div>
                        <div class="fw-semibold">@o.ItemCount</div>
                    </div>
                    <div class="col-md-2 col-4">
                        <div class="text-muted small text-uppercase">Total</div>
                        <div class="mv-price">@o.Total.ToString("0.00")</div>
                    </div>
                    <div class="col-md-2 col-4">
                        <div class="text-muted small text-uppercase mb-1">Status</div>
                        <span class="badge rounded-pill @badgeCss"><i class="bi @badgeIcon me-1"></i>@badgeLabel</span>
                    </div>
                    <div class="col-md-1 col-12 text-md-end">
                        <a asp-action="Details" asp-route-id="@o.Id" class="btn btn-outline-primary btn-sm w-100"><i class="bi bi-eye me-1"></i>View</a>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                    <a class="page-link" asp-route-page="@(Model.PageNumber - 1)">Previous</a>
                </li>
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(Model.HasNext ? "" : "disabled")">
                    <a class="page-link" asp-route-page="@(Model.PageNumber + 1)">Next</a>
                </li>
            </ul>
        </nav>
        <p class="text-center text-muted small">Showing page @Model.PageNumber of @Model.TotalPages</p>
    }
}
