@using Domain.Enums
@model Application.Common.Models.PaginatedList<Application.Coupons.Queries.CouponDto>
@{
    ViewData["Title"] = "My coupons";
    var search   = ViewBag.Search as string;
    var isActive = ViewBag.IsActive as bool?;

    var route = new Dictionary<string, string?>();
    if (!string.IsNullOrWhiteSpace(search)) route["search"]   = search;
    if (isActive.HasValue)                  route["isActive"] = isActive.Value.ToString().ToLower();
}

<div class="mv-list">
    <div class="mv-list-toolbar">
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>New coupon</a>
    </div>

    <div class="card shadow-sm mb-3">
        <form method="get">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Search by code</label>
                        <input name="search" value="@search" class="form-control" placeholder="Search by code…" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Status</label>
                        <select name="isActive" class="form-select">
                            <option value="" selected="@(isActive is null)">All statuses</option>
                            <option value="true"  selected="@(isActive == true)">Active</option>
                            <option value="false" selected="@(isActive == false)">Inactive</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="card-footer text-end">
                @if (route.Any())
                {
                    <a asp-action="Index" class="btn btn-secondary me-1">Clear</a>
                }
                <button class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
            </div>
        </form>
    </div>

    <div class="card shadow-sm">
        @if (!Model.Items.Any())
        {
            <div class="card-body">
                <div class="mv-empty">
                    <div class="mv-empty-icon"><i class="bi bi-ticket-perforated"></i></div>
                    <h6>No coupons yet</h6>
                    <p class="text-muted small mb-3">Run a promotion across your store with a discount code.</p>
                    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create your first coupon</a>
                </div>
            </div>
        }
        else
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="mv-list-table table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Type</th>
                                <th class="text-end">Value</th>
                                <th class="text-end">Min order</th>
                                <th class="text-center">Used</th>
                                <th>Window</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var c in Model.Items)
                        {
                            <tr>
                                <td><code>@c.Code</code></td>
                                <td>@(c.DiscountType == CouponDiscountType.Percentage ? "Percentage" : "Fixed")</td>
                                <td class="text-end fw-semibold">@(c.DiscountType == CouponDiscountType.Percentage ? $"{c.DiscountValue:0.##}%" : $"{c.DiscountValue:0.00}")</td>
                                <td class="text-end">@c.MinimumOrderAmount.ToString("0.00")</td>
                                <td class="text-center">@c.UsedCount@(c.MaxUses.HasValue ? $" / {c.MaxUses}" : "")</td>
                                <td class="small text-muted">@(c.StartsAtUtc?.ToString("MMM d") ?? "—") → @(c.ExpiresAtUtc?.ToString("MMM d") ?? "—")</td>
                                <td class="text-center">
                                    @if (c.IsActive) { <span class="mv-pill mv-pill-success"><i class="bi bi-check-circle"></i>Active</span> }
                                    else { <span class="mv-pill mv-pill-muted"><i class="bi bi-pause-circle"></i>Inactive</span> }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Edit" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" class="d-inline" onsubmit="return confirm('Delete?');">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer">
                @await Html.PartialAsync("_Pagination", (Model.PageNumber, Model.TotalPages, Model.TotalCount, Model.HasPrevious, Model.HasNext, route))
            </div>
        }
    </div>
</div>
