@model Application.Products.Queries.GetPublicProductBySlug.PublicProductDetailDto
@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.FirstOrDefault();
}

<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="">@Model.CategoryName</a></li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-7">
        @if (mainImage is not null)
        {
            <img id="mainImage" src="@mainImage.Url" class="mv-gallery-main mb-2" />
        }
        else
        {
            <div class="mv-gallery-main d-flex justify-content-center align-items-center mb-2 bg-body-secondary"><i class="bi bi-image display-1 text-muted"></i></div>
        }
        @if (Model.Images.Count > 1)
        {
            <div class="row g-2">
                @foreach (var img in Model.Images)
                {
                    <div class="col-3">
                        <img src="@img.Url" class="mv-thumb @(img.IsMain ? "active" : "")" data-url="@img.Url" />
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-lg-5">
        <div class="card mv-card">
            <div class="card-body">
                <div class="text-muted small text-uppercase">@Model.CategoryName</div>
                <h2 class="mt-1 mb-2" style="letter-spacing:-0.01em">@Model.Name</h2>

                <div class="d-flex align-items-center gap-3 flex-wrap mb-3">
                    @if (!string.IsNullOrEmpty(Model.StoreSlug))
                    {
                        <a asp-controller="Stores" asp-action="Index" asp-route-slug="@Model.StoreSlug" class="mv-store-link"><i class="bi bi-shop me-1"></i>@Model.StoreName</a>
                    }
                    @if (Model.ReviewCount > 0)
                    {
                        <span class="mv-rating"><i class="bi bi-star-fill"></i> @Model.AverageRating.ToString("0.0")</span>
                        <small class="text-muted">(@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s"))</small>
                    }
                </div>

                <div class="mb-3" style="font-size:1.6rem;">
                    <span class="mv-price" style="font-size:1.6rem;">@Model.BasePrice.ToString("0.00")</span>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted">@Model.Description</p>
                }

                @if (Model.Variants.Any())
                {
                    <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Choose variant</label>
                            <select name="productVariantId" class="form-select" required>
                                <option value="">— Select —</option>
                                @foreach (var v in Model.Variants)
                                {
                                    var label = $"{v.Sku}";
                                    if (!string.IsNullOrEmpty(v.Color)) label += $" · {v.Color}";
                                    if (!string.IsNullOrEmpty(v.Size)) label += $" · {v.Size}";
                                    label += $" — {v.Price.ToString("0.00")} ({v.StockQuantity} in stock)";
                                    <option value="@v.Id" disabled="@(v.StockQuantity == 0)">@label</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex gap-2 align-items-center mb-3">
                            <input type="number" name="quantity" min="1" value="1" class="form-control" style="max-width:100px" />
                            <button type="submit" class="btn btn-primary flex-grow-1"><i class="bi bi-cart-plus me-1"></i>Add to cart</button>
                        </div>
                    </form>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-grid">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@Model.Id" />
                            <input type="hidden" name="slug" value="@Model.Slug" />
                            <button type="submit" class="btn btn-outline-secondary"><i class="bi bi-heart me-1"></i>Add to wishlist</button>
                        </form>
                    }
                }

                <hr class="my-3" />
                <div class="d-flex gap-3 small text-muted">
                    <span><i class="bi bi-truck me-1"></i>Fast shipping</span>
                    <span><i class="bi bi-shield-check me-1"></i>Secure checkout</span>
                    <span><i class="bi bi-arrow-counterclockwise me-1"></i>Easy returns</span>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var reviews = ViewBag.Reviews as List<Application.Reviews.Queries.PublicReviewDto> ?? new();
}

<hr class="my-4" />
<h4 class="mb-3"><i class="bi bi-chat-square-text me-2"></i>Reviews (@reviews.Count)</h4>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="card shadow-sm mb-4">
        <div class="card-header"><h6 class="mb-0">Leave a review</h6></div>
        <form asp-controller="Reviews" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productId" value="@Model.Id" />
            <input type="hidden" name="slug" value="@Model.Slug" />
            <div class="card-body">
                <div class="mb-2">
                    <label class="form-label small">Rating</label>
                    <select name="rating" class="form-select" style="max-width:160px">
                        <option value="5">★★★★★ (5)</option>
                        <option value="4">★★★★ (4)</option>
                        <option value="3">★★★ (3)</option>
                        <option value="2">★★ (2)</option>
                        <option value="1">★ (1)</option>
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label small">Title</label>
                    <input name="title" class="form-control" maxlength="200" />
                </div>
                <div class="mb-2">
                    <label class="form-label small">Comment</label>
                    <textarea name="comment" class="form-control" rows="3" maxlength="2000"></textarea>
                </div>
            </div>
            <div class="card-footer text-end"><button class="btn btn-primary"><i class="bi bi-send me-1"></i>Submit review</button></div>
        </form>
    </div>
}

@if (!reviews.Any())
{
    <p class="text-muted">No reviews yet. Be the first to review this product.</p>
}
else
{
    foreach (var rv in reviews)
    {
        <div class="card shadow-sm mb-2">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <span class="text-warning">@(new string('★', rv.Rating))<span class="text-muted">@(new string('★', 5 - rv.Rating))</span></span>
                        @if (rv.VerifiedPurchase) { <span class="badge bg-success ms-2">Verified Purchase</span> }
                    </div>
                    <small class="text-muted">@rv.CreatedAtUtc.ToString("yyyy-MM-dd")</small>
                </div>
                @if (!string.IsNullOrEmpty(rv.Title)) { <h6 class="mt-2 mb-1">@rv.Title</h6> }
                @if (!string.IsNullOrEmpty(rv.Comment)) { <p class="mb-0">@rv.Comment</p> }

                @if (!string.IsNullOrEmpty(rv.VendorReply))
                {
                    <div class="mt-3 ps-3 border-start">
                        <div class="small text-muted mb-1"><i class="bi bi-shop me-1"></i>Vendor reply · @rv.VendorRepliedAtUtc?.ToString("yyyy-MM-dd")</div>
                        <p class="mb-0 fst-italic">@rv.VendorReply</p>
                    </div>
                }
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        document.querySelectorAll('.mv-thumb').forEach(t => {
            t.addEventListener('click', () => {
                const main = document.getElementById('mainImage');
                if (main) main.src = t.dataset.url;
                document.querySelectorAll('.mv-thumb').forEach(x => x.classList.remove('active'));
                t.classList.add('active');
            });
        });
    </script>
}
