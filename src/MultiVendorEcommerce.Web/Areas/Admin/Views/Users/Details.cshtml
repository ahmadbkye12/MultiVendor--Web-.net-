@model Application.Common.Interfaces.UserSummary
@{
    ViewData["Title"] = $"User — {Model.FullName}";
    var allRoles = (string[])ViewBag.AllRoles!;
}

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">User</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Full name</dt> <dd class="col-sm-8">@Model.FullName</dd>
                    <dt class="col-sm-4">Email</dt>     <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Joined</dt>    <dd class="col-sm-8">@Model.CreatedAtUtc.ToString("u")</dd>
                    <dt class="col-sm-4">Roles</dt>
                    <dd class="col-sm-8">
                        @foreach (var r in Model.Roles)
                        { <span class="badge bg-info text-dark me-1">@r</span> }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm">
            <div class="card-header"><h5 class="mb-0">Edit roles</h5></div>
            <form asp-action="SetRoles" asp-route-id="@Model.Id" method="post">
                <div class="card-body">
                    @foreach (var r in allRoles)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="roles" value="@r"
                                   id="role-@r" @(Model.Roles.Contains(r) ? "checked" : "") />
                            <label class="form-check-label" for="role-@r">@r</label>
                        </div>
                    }
                </div>
                <div class="card-footer text-end">
                    <a asp-action="Index" class="btn btn-secondary">Back</a>
                    <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save roles</button>
                </div>
            </form>
        </div>
    </div>
</div>
