@model Application.VendorStores.Queries.GetPublicStoreBySlug.PublicStoreDto
@{
    ViewData["Title"] = Model.Name;
    var products = (Application.Common.Models.PaginatedList<Application.Products.Queries.GetPublicProducts.PublicProductCardDto>)ViewBag.Products;
}

<!-- Banner -->
<div class="mv-storefront-banner mb-4">
    @if (!string.IsNullOrEmpty(Model.BannerUrl))
    {
        <img src="@Model.BannerUrl" alt="@Model.Name" />
    }
    else
    {
        <div style="background: var(--mv-grad-1); height: 240px;"></div>
    }
    <div class="mv-storefront-overlay"></div>
    <div class="position-absolute bottom-0 start-0 p-4 text-white">
        <div class="d-flex align-items-end gap-3">
            @if (!string.IsNullOrEmpty(Model.LogoUrl))
            {
                <img src="@Model.LogoUrl" class="rounded" style="width:80px;height:80px;object-fit:cover;border:3px solid #fff;box-shadow:var(--mv-shadow-md);" />
            }
            else
            {
                <div class="rounded bg-white d-flex justify-content-center align-items-center" style="width:80px;height:80px;border:3px solid #fff;"><i class="bi bi-shop fs-2 text-muted"></i></div>
            }
            <div>
                <h1 class="mb-0" style="text-shadow:0 2px 8px rgba(0,0,0,.4);">@Model.Name</h1>
                <small class="opacity-75">@Model.VendorBusiness · @Model.ProductCount product@(Model.ProductCount == 1 ? "" : "s")</small>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Description) || !string.IsNullOrEmpty(Model.ContactEmail) || !string.IsNullOrEmpty(Model.ContactPhone))
{
    <div class="card mv-card mb-4">
        <div class="card-body d-flex flex-wrap gap-3 justify-content-between align-items-start">
            <div class="flex-grow-1">
                @if (!string.IsNullOrEmpty(Model.Description))
                { <p class="mb-0 text-muted">@Model.Description</p> }
            </div>
            <div class="text-muted small">
                @if (!string.IsNullOrEmpty(Model.ContactEmail))
                { <div><i class="bi bi-envelope me-1"></i>@Model.ContactEmail</div> }
                @if (!string.IsNullOrEmpty(Model.ContactPhone))
                { <div><i class="bi bi-telephone me-1"></i>@Model.ContactPhone</div> }
            </div>
        </div>
    </div>
}

<div class="mv-section-head">
    <h4 class="mb-0"><i class="bi bi-bag me-2"></i>Products from @Model.Name</h4>
</div>
<hr class="mt-2 mb-3" />

@if (!products.Items.Any())
{
    <div class="alert alert-info text-center py-5">
        <i class="bi bi-box display-4 d-block mb-2"></i>
        This store hasn't published any products yet.
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var p in products.Items)
        {
            var hasDiscount = p.MinVariantPrice.HasValue && p.MinVariantPrice < p.BasePrice;
            <div class="col-md-3 col-sm-6">
                <div class="card mv-card h-100 position-relative">
                    @if (hasDiscount) { <span class="mv-badge-sale">SALE</span> }
                    <a asp-controller="Products" asp-action="Details" asp-route-slug="@p.Slug" class="text-decoration-none text-reset">
                        <div class="mv-img-wrap">
                            @if (!string.IsNullOrEmpty(p.MainImageUrl))
                            { <img src="@p.MainImageUrl" class="card-img-top" style="height:180px;object-fit:cover" /> }
                            else
                            { <div class="card-img-top bg-body-secondary d-flex justify-content-center align-items-center" style="height:180px"><i class="bi bi-image display-4 text-muted"></i></div> }
                        </div>
                        <div class="card-body">
                            <div class="text-muted small text-uppercase">@p.CategoryName</div>
                            <h6 class="card-title mt-1 mb-1">@p.Name</h6>
                            <div class="d-flex align-items-baseline">
                                <span class="mv-price">@((p.MinVariantPrice ?? p.BasePrice).ToString("0.00"))</span>
                                @if (hasDiscount) { <span class="mv-price-old">@p.BasePrice.ToString("0.00")</span> }
                            </div>
                            @if (p.ReviewCount > 0)
                            {
                                <div class="mt-1">
                                    <span class="mv-rating"><i class="bi bi-star-fill"></i> @p.AverageRating.ToString("0.0")</span>
                                    <small class="text-muted">(@p.ReviewCount)</small>
                                </div>
                            }
                        </div>
                    </a>
                </div>
            </div>
        }
    </div>
}
