@model Web.Models.ViewModels.Vendor.Products.ProductEditViewModel
@{
    ViewData["Title"] = $"Edit — {Model.Name}";
}

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="alert alert-danger small d-none"></div>

    <div class="card shadow-sm">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Edit product</h5>
            <span class="text-muted small">Store: <strong>@Model.StoreName</strong> · Slug: <code>@Model.Slug</code> · Status:
                @if (Model.ApprovalStatus == "Approved") { <span class="badge bg-success">Approved</span> }
                else if (Model.ApprovalStatus == "Pending") { <span class="badge bg-warning text-dark">Pending</span> }
                else { <span class="badge bg-danger">Rejected</span> }
            </span>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-12">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label"></label>
                    <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="BasePrice" class="form-label"></label>
                    <input asp-for="BasePrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="BasePrice" class="text-danger small"></span>
                </div>
                <div class="col-md-12">
                    <label asp-for="Description" class="form-label"></label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                </div>
                <div class="col-md-12">
                    <div class="form-check">
                        <input asp-for="IsPublished" class="form-check-input" />
                        <label asp-for="IsPublished" class="form-check-label"></label>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save changes</button>
        </div>
    </div>
</form>

<div class="alert alert-info mt-3 small">
    <i class="bi bi-info-circle me-1"></i>Editing core info resets the approval status to <strong>Pending</strong>; an admin will need to re-approve.
</div>

@{
    var detail = ViewBag.Detail as Application.Products.Queries.GetMyProductById.MyProductDetailDto;
}

@if (detail is not null)
{
    <div class="row g-3 mt-3">
        <!-- Image management -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-images me-2"></i>Images</h5></div>
                <div class="card-body">
                    @if (!detail.Images.Any())
                    { <p class="text-muted">No images yet.</p> }
                    else
                    {
                        <div class="row g-2">
                            @foreach (var img in detail.Images)
                            {
                                <div class="col-6">
                                    <div class="position-relative">
                                        <img src="@img.Url" class="img-thumbnail w-100" style="height:140px;object-fit:cover" />
                                        @if (img.IsMain)
                                        { <span class="badge bg-primary position-absolute top-0 start-0 m-1">Main</span> }
                                        <div class="d-flex gap-1 mt-1">
                                            @if (!img.IsMain)
                                            {
                                                <form asp-action="SetMainImage" asp-route-id="@detail.Id" method="post" class="flex-grow-1">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="imageId" value="@img.Id" />
                                                    <button class="btn btn-sm btn-outline-primary w-100" title="Make main"><i class="bi bi-star"></i></button>
                                                </form>
                                            }
                                            <form asp-action="DeleteImage" asp-route-id="@detail.Id" method="post" class="flex-grow-1" onsubmit="return confirm('Delete this image?');">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="imageId" value="@img.Id" />
                                                <button class="btn btn-sm btn-outline-danger w-100" title="Delete"><i class="bi bi-trash"></i></button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    <hr />
                    <form asp-action="AddImage" asp-route-id="@detail.Id" method="post" enctype="multipart/form-data" class="d-flex gap-2">
                        @Html.AntiForgeryToken()
                        <input type="file" name="imageFile" accept="image/*" class="form-control" required />
                        <button class="btn btn-primary"><i class="bi bi-plus-lg"></i></button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Variant management -->
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header"><h5 class="mb-0"><i class="bi bi-grid-3x3 me-2"></i>Variants</h5></div>
                <div class="card-body">
                    @if (!detail.Variants.Any())
                    { <p class="text-muted mb-0">No variants yet.</p> }
                    @foreach (var v in detail.Variants)
                    {
                        <div class="border rounded p-2 mb-2">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <span><code>@v.Sku</code> @if (!v.IsActive) { <span class="badge bg-secondary ms-1">inactive</span> }</span>
                                <form asp-action="DeleteVariant" asp-route-id="@detail.Id" method="post" class="d-inline" onsubmit="return confirm('Delete this variant?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="variantId" value="@v.Id" />
                                    <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                            <form asp-action="UpdateVariant" asp-route-id="@detail.Id" method="post" class="row g-1 align-items-center">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="variantId" value="@v.Id" />
                                <div class="col-3"><input name="color" value="@v.Color" placeholder="Color" class="form-control form-control-sm" /></div>
                                <div class="col-2"><input name="size" value="@v.Size" placeholder="Size" class="form-control form-control-sm" /></div>
                                <div class="col-2"><input name="price" value="@v.Price" type="number" step="0.01" min="0.01" class="form-control form-control-sm text-end" required /></div>
                                <div class="col-2"><input name="stockQuantity" value="@v.StockQuantity" type="number" min="0" class="form-control form-control-sm text-end" required /></div>
                                <div class="col-1 form-check ms-2"><input name="isActive" value="true" type="checkbox" class="form-check-input" @(v.IsActive ? "checked" : "") /></div>
                                <div class="col-1"><button class="btn btn-sm btn-outline-primary w-100"><i class="bi bi-save"></i></button></div>
                            </form>
                        </div>
                    }
                </div>
                <div class="card-body border-top">
                    <h6>Add new variant</h6>
                    <form asp-action="AddVariant" asp-route-id="@detail.Id" method="post" class="row g-2">
                        @Html.AntiForgeryToken()
                        <div class="col-4"><input name="sku" class="form-control form-control-sm" placeholder="SKU" required /></div>
                        <div class="col-3"><input name="color" class="form-control form-control-sm" placeholder="Color" /></div>
                        <div class="col-2"><input name="size" class="form-control form-control-sm" placeholder="Size" /></div>
                        <div class="col-2"><input name="price" type="number" step="0.01" min="0.01" value="1.00" class="form-control form-control-sm" required /></div>
                        <div class="col-1"><input name="stockQuantity" type="number" min="0" value="0" class="form-control form-control-sm" required /></div>
                        <div class="col-12"><button class="btn btn-sm btn-primary"><i class="bi bi-plus-lg me-1"></i>Add variant</button></div>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
