@model Application.Products.Queries.GetMyProductById.MyProductDetailDto
@{
    ViewData["Title"] = $"Delete — {Model.Name}";
}

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white"><i class="bi bi-exclamation-triangle me-1"></i>Confirm deletion</div>
    <div class="card-body">
        <p>You're about to delete <strong>@Model.Name</strong> from store <em>@Model.StoreName</em>.</p>
        <ul class="text-muted small mb-0">
            <li>Slug: <code>@Model.Slug</code></li>
            <li>Variants: @Model.Variants.Count</li>
            <li>Images: @Model.Images.Count</li>
        </ul>
    </div>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        </div>
    </form>
</div>
