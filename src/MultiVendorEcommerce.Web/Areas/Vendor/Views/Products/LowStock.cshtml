@model List<Application.ProductVariants.Queries.GetLowStockVariants.LowStockVariantDto>
@{
    ViewData["Title"] = "Low stock";
    var threshold = (int)(ViewBag.Threshold ?? 5);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Low Stock Variants</h2>
    <form method="get" class="d-flex gap-2">
        <label class="col-form-label small me-2">Threshold:</label>
        <input type="number" name="threshold" min="0" max="1000" value="@threshold" class="form-control" style="max-width:100px" />
        <button class="btn btn-outline-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
    </form>
</div>

@if (!Model.Any())
{
    <div class="alert alert-success"><i class="bi bi-check-circle me-1"></i>All variants are above the threshold.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Product</th>
                        <th>SKU</th>
                        <th>Color</th>
                        <th>Size</th>
                        <th class="text-end">Stock</th>
                        <th class="text-center">Active</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var v in Model)
                {
                    <tr class="@(v.StockQuantity == 0 ? "table-danger" : "table-warning")">
                        <td><strong>@v.ProductName</strong></td>
                        <td><code>@v.Sku</code></td>
                        <td>@(v.Color ?? "—")</td>
                        <td>@(v.Size ?? "—")</td>
                        <td class="text-end fw-bold">@v.StockQuantity</td>
                        <td class="text-center">@(v.IsActive ? "Yes" : "No")</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@v.ProductId" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil me-1"></i>Restock</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
