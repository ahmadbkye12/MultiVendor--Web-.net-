@model Web.Models.ViewModels.Profile.ProfileViewModel
@{
    ViewData["Title"] = "Profile";
}

<h2 class="mb-3"><i class="bi bi-person-circle me-2"></i>My Profile</h2>

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card mv-card overflow-hidden">
            <!-- Gradient header band -->
            <div style="height: 80px; background: var(--mv-grad-1);"></div>
            <div class="card-body text-center" style="margin-top:-50px;">
                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" class="rounded-circle mb-2" style="width:100px;height:100px;object-fit:cover;border:4px solid #fff;box-shadow:var(--mv-shadow-md);" />
                }
                else
                {
                    <div class="rounded-circle bg-body mx-auto mb-2 d-flex justify-content-center align-items-center" style="width:100px;height:100px;border:4px solid #fff;box-shadow:var(--mv-shadow-md);"><i class="bi bi-person fs-1 text-muted"></i></div>
                }
                <h5 class="mb-1">@Model.FullName</h5>
                <p class="text-muted small mb-2"><i class="bi bi-envelope me-1"></i>@Model.Email</p>
                <div class="mb-2">
                    @foreach (var r in Model.Roles)
                    { <span class="badge bg-primary me-1">@r</span> }
                </div>
            </div>
            <div class="card-footer bg-white border-0 pb-3 d-grid gap-2">
                <a asp-action="ChangePassword" class="btn btn-outline-secondary btn-sm"><i class="bi bi-key me-1"></i>Change password</a>
                <a asp-controller="Addresses" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-geo-alt me-1"></i>Manage addresses</a>
                <a asp-controller="Orders" asp-action="Index" class="btn btn-outline-secondary btn-sm"><i class="bi bi-bag me-1"></i>My orders</a>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card mv-card">
            <form asp-action="Index" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="ProfileImageUrl" />
                <div class="card-header bg-white border-0 pt-3"><h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Edit profile</h5></div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>
                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label small fw-semibold"></label>
                        <input asp-for="FullName" class="form-control" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ProfileImageFile" class="form-label small fw-semibold"></label>
                        <input asp-for="ProfileImageFile" type="file" accept="image/*" class="form-control" />
                        <small class="text-muted">PNG or JPG, recommended square.</small>
                    </div>
                </div>
                <div class="card-footer bg-white border-0 pb-3 text-end">
                    <button class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Save changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
