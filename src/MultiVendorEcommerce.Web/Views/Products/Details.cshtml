@model Application.Products.Queries.GetPublicProductBySlug.PublicProductDetailDto
@{
    ViewData["Title"] = Model.Name;
    var mainImage = Model.Images.FirstOrDefault(i => i.IsMain) ?? Model.Images.FirstOrDefault();
    var minVar = Model.Variants.Count > 0 ? Model.Variants.Min(v => v.Price) : (decimal?)null;
    var showFromPrice = minVar.HasValue && minVar.Value < Model.BasePrice;
}

<nav aria-label="breadcrumb" class="mv-pdp-breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-action="Index">Products</a></li>
        <li class="breadcrumb-item"><a asp-action="Index" asp-route-categoryId="">@Model.CategoryName</a></li>
        <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
    </ol>
</nav>

<div class="row g-4 g-xl-5 align-items-start">
    <div class="col-lg-7 col-xl-8">
        <div class="mv-pdp-gallery-wrap mb-3">
            <div class="mv-pdp-gallery-inner">
                @if (mainImage is not null)
                {
                    <img id="mainImage" src="@mainImage.Url" alt="@Model.Name" class="mv-pdp-main-img" />
                }
                else
                {
                    <div id="mainImage" class="mv-pdp-main-ph d-flex justify-content-center align-items-center">
                        <i class="bi bi-image display-1 text-muted"></i>
                    </div>
                }
            </div>
        </div>
        @if (Model.Images.Count > 1)
        {
            <div class="row g-2 g-md-3">
                @foreach (var img in Model.Images)
                {
                    <div class="col-3">
                        <img src="@img.Url" alt="" class="mv-pdp-thumb @(img.IsMain ? "active" : "")" data-url="@img.Url" />
                    </div>
                }
            </div>
        }
    </div>

    <div class="col-lg-5 col-xl-4">
        <div class="card mv-card mv-pdp-buy border-0 mv-pdp-buy-sticky">
            <div class="card-body p-4">
                <span class="mv-product-card-v2__cat d-inline-block mb-2">@Model.CategoryName</span>
                <h1 class="h2 fw-bold mb-3" style="letter-spacing:-0.02em;color:#0f172a">@Model.Name</h1>

                <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
                    @if (!string.IsNullOrEmpty(Model.StoreSlug))
                    {
                        <a asp-controller="Stores" asp-action="Index" asp-route-slug="@Model.StoreSlug" class="mv-store-link fw-semibold"><i class="bi bi-shop me-1"></i>@Model.StoreName</a>
                    }
                    @if (Model.ReviewCount > 0)
                    {
                        <span class="mv-rating"><i class="bi bi-star-fill"></i> @Model.AverageRating.ToString("0.0")</span>
                        <small class="text-muted">(@Model.ReviewCount review@(Model.ReviewCount == 1 ? "" : "s"))</small>
                    }
                </div>

                <div class="mb-3 pb-3 border-bottom border-light">
                    @if (showFromPrice)
                    {
                        <div class="text-muted small text-uppercase fw-semibold mb-1" style="letter-spacing:.06em">From</div>
                        <div class="mv-pdp-price"><sup class="mv-pdp-price-currency">$</sup>@minVar!.Value.ToString("0.00")</div>
                        <small class="text-muted">List price <span class="text-decoration-line-through">$@Model.BasePrice.ToString("0.00")</span></small>
                    }
                    else
                    {
                        <div class="mv-pdp-price"><sup class="mv-pdp-price-currency">$</sup>@Model.BasePrice.ToString("0.00")</div>
                        @if (Model.Variants.Count > 1)
                        {
                            <small class="text-muted">Price may vary by variant.</small>
                        }
                    }
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <p class="text-muted mb-4" style="line-height:1.65">@Model.Description</p>
                }

                @if (Model.Variants.Any())
                {
                    <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <div class="mb-3">
                            <label class="form-label fw-semibold small">Choose variant</label>
                            <select name="productVariantId" class="form-select" required>
                                <option value="">— Select a variant —</option>
                                @foreach (var v in Model.Variants)
                                {
                                    var label = $"{v.Sku}";
                                    if (!string.IsNullOrEmpty(v.Color)) label += $" · {v.Color}";
                                    if (!string.IsNullOrEmpty(v.Size))  label += $" · {v.Size}";
                                    label += $"  —  ${v.Price.ToString("0.00")}  ({v.StockQuantity} in stock)";
                                    <option value="@v.Id" disabled="@(v.StockQuantity == 0)">@label</option>
                                }
                            </select>
                        </div>
                        <div class="d-flex gap-2 align-items-stretch mb-3">
                            <div class="input-group" style="max-width:120px;">
                                <input type="number" name="quantity" min="1" value="1" class="form-control text-center" />
                            </div>
                            <button type="submit" class="btn btn-primary flex-grow-1 btn-lg">
                                <i class="bi bi-cart-plus me-2"></i>Add to cart
                            </button>
                        </div>
                    </form>
                }
                else
                {
                    <form asp-controller="Cart" asp-action="Add" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <div class="d-flex gap-2 align-items-stretch mb-3">
                            <div class="input-group" style="max-width:120px;">
                                <input type="number" name="quantity" min="1" value="1" class="form-control text-center" />
                            </div>
                            <button type="submit" class="btn btn-primary flex-grow-1 btn-lg">
                                <i class="bi bi-cart-plus me-2"></i>Add to cart
                            </button>
                        </div>
                    </form>
                }

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Wishlist" asp-action="Add" method="post" class="d-grid mb-2">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="productId" value="@Model.Id" />
                        <input type="hidden" name="slug" value="@Model.Slug" />
                        <button type="submit" class="btn btn-outline-secondary">
                            <i class="bi bi-heart me-1"></i>Save to wishlist
                        </button>
                    </form>
                }

                <div class="mv-pdp-trust mt-4">
                    <span><i class="bi bi-truck"></i>Fast shipping</span>
                    <span><i class="bi bi-shield-check"></i>Secure checkout</span>
                    <span><i class="bi bi-arrow-counterclockwise"></i>Easy returns</span>
                </div>
            </div>
        </div>
    </div>
</div>

@{
    var reviews = ViewBag.Reviews as List<Application.Reviews.Queries.PublicReviewDto> ?? new();
}

<div class="mt-5 pt-3" style="border-top:1px solid #f1f5f9;">
    <h4 class="fw-bold mb-4" style="color:#0f172a;letter-spacing:-.01em;">
        <i class="bi bi-chat-square-quote me-2" style="color:#6366f1;"></i>Customer Reviews
        <span class="text-muted fw-normal fs-6 ms-2">(@reviews.Count)</span>
    </h4>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div style="background:#fff;border-radius:1rem;border:1px solid #f1f5f9;box-shadow:0 2px 16px rgba(0,0,0,.05);overflow:hidden;margin-bottom:2rem;">
            <div style="padding:1.15rem 1.5rem;border-bottom:1px solid #f1f5f9;">
                <h6 class="mb-0 fw-bold" style="color:#0f172a;">Write a review</h6>
            </div>
            <form asp-controller="Reviews" asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <input type="hidden" name="slug" value="@Model.Slug" />
                <div class="p-4 d-flex flex-column gap-3">
                    <div>
                        <label class="form-label">Your rating</label>
                        <select name="rating" class="form-select" style="max-width:180px">
                            <option value="5">★★★★★  Excellent (5)</option>
                            <option value="4">★★★★  Good (4)</option>
                            <option value="3">★★★  Average (3)</option>
                            <option value="2">★★  Poor (2)</option>
                            <option value="1">★  Terrible (1)</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Title</label>
                        <input name="title" class="form-control" maxlength="200" placeholder="Summarise your experience…" />
                    </div>
                    <div>
                        <label class="form-label">Comment</label>
                        <textarea name="comment" class="form-control" rows="4" maxlength="2000"
                                  placeholder="Share your detailed thoughts…"></textarea>
                    </div>
                </div>
                <div class="px-4 pb-4 text-end">
                    <button class="btn btn-primary px-4">
                        <i class="bi bi-send me-2"></i>Submit review
                    </button>
                </div>
            </form>
        </div>
    }

    @if (!reviews.Any())
    {
        <div class="mv-empty-state py-4">
            <div class="mv-empty-state__icon"><i class="bi bi-chat-square-text"></i></div>
            <h4>No reviews yet</h4>
            <p>Be the first to share your experience with this product.</p>
        </div>
    }
    else
    {
        <div class="d-flex flex-column gap-3">
            @foreach (var rv in reviews)
            {
                <div style="background:#fff;border-radius:1rem;border:1px solid #f1f5f9;box-shadow:0 2px 16px rgba(0,0,0,.05);padding:1.25rem 1.5rem;">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <span style="color:#f59e0b;">@(new string('★', rv.Rating))<span style="color:#e2e8f0;">@(new string('★', 5 - rv.Rating))</span></span>
                            @if (rv.VerifiedPurchase)
                            { <span style="background:#dcfce7;color:#15803d;padding:.2rem .55rem;border-radius:2rem;font-size:.7rem;font-weight:700;">✓ Verified</span> }
                        </div>
                        <small class="text-muted">@rv.CreatedAtUtc.ToString("MMM d, yyyy")</small>
                    </div>
                    @if (!string.IsNullOrEmpty(rv.Title))
                    { <h6 class="fw-bold mb-1" style="color:#0f172a;">@rv.Title</h6> }
                    @if (!string.IsNullOrEmpty(rv.Comment))
                    { <p class="mb-0 text-muted" style="font-size:.9rem;line-height:1.6;">@rv.Comment</p> }

                    @if (!string.IsNullOrEmpty(rv.VendorReply))
                    {
                        <div class="mt-3 ps-3" style="border-left:3px solid #6366f1;background:#f8f8ff;border-radius:0 .5rem .5rem 0;padding:.75rem;">
                            <div class="small fw-semibold mb-1" style="color:#4f46e5;">
                                <i class="bi bi-shop me-1"></i>Vendor reply
                                @if (rv.VendorRepliedAtUtc.HasValue)
                                { <span class="text-muted fw-normal">· @rv.VendorRepliedAtUtc.Value.ToString("MMM d, yyyy")</span> }
                            </div>
                            <p class="mb-0 small fst-italic text-muted">@rv.VendorReply</p>
                        </div>
                    }
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.mv-pdp-thumb').forEach(t => {
            t.addEventListener('click', () => {
                const main = document.getElementById('mainImage');
                if (main && main.tagName === 'IMG') main.src = t.dataset.url;
                document.querySelectorAll('.mv-pdp-thumb').forEach(x => x.classList.remove('active'));
                t.classList.add('active');
            });
        });
    </script>
}
