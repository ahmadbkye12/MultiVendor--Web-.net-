@model List<Application.Wishlist.WishlistItemDto>
@{
    ViewData["Title"] = "Wishlist";
}

<div class="mv-page-header">
    <div>
        <h1 class="mv-page-header__title"><i class="bi bi-heart"></i>My Wishlist</h1>
        <p class="mv-page-header__sub">@Model.Count item@(Model.Count == 1 ? "" : "s") saved for later</p>
    </div>
</div>

@if (!Model.Any())
{
    <div class="mv-empty-state">
        <div class="mv-empty-state__icon"><i class="bi bi-heart"></i></div>
        <h4>Your wishlist is empty</h4>
        <p>Save products you love and come back to them any time.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary">
            <i class="bi bi-grid-3x3-gap me-1"></i>Discover products
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var w in Model)
        {
            <div class="col-xl-3 col-md-4 col-sm-6">
                <div class="mv-product-card-v2 position-relative h-100" style="border-radius:1.1rem;overflow:hidden;">
                    @if (!w.InStock)
                    { <span class="mv-badge-sale" style="background:#64748b;z-index:3;position:absolute;top:.75rem;left:.75rem;">OUT OF STOCK</span> }

                    <div style="aspect-ratio:4/3;overflow:hidden;position:relative;background:var(--mv-grad-soft);">
                        @if (!string.IsNullOrEmpty(w.ImageUrl))
                        {
                            <img src="@w.ImageUrl" style="width:100%;height:100%;object-fit:cover;" alt="@w.ProductName" loading="lazy" />
                        }
                        else
                        {
                            <div class="d-flex align-items-center justify-content-center h-100">
                                <i class="bi bi-image text-muted" style="font-size:2.5rem;"></i>
                            </div>
                        }
                    </div>

                    <div class="p-3 d-flex flex-column gap-2">
                        <h3 class="mb-0" style="font-size:.92rem;font-weight:700;line-height:1.3;color:#0f172a;
                                                 display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                            <a asp-controller="Products" asp-action="Details" asp-route-slug="@w.ProductSlug"
                               class="stretched-link text-reset text-decoration-none">@w.ProductName</a>
                        </h3>

                        <div class="d-flex align-items-baseline gap-1 mt-1">
                            <span class="mv-product-card-v2__currency">$</span>
                            <span class="mv-product-card-v2__price">@w.Price.ToString("0.00")</span>
                        </div>

                        <form asp-action="Remove" asp-route-id="@w.Id" method="post" style="position:relative;z-index:2;">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-outline-danger w-100">
                                <i class="bi bi-heart-fill me-1"></i>Remove from wishlist
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
