@model Application.VendorStores.Queries.GetPublicStoreBySlug.PublicStoreDto
@{
    ViewData["Title"] = Model.Name;
    var products = (Application.Common.Models.PaginatedList<Application.Products.Queries.GetPublicProducts.PublicProductCardDto>)ViewBag.Products;
}

<!-- Store Hero Banner -->
<div class="mv-store-hero mb-4">
    <div class="mv-store-hero__banner">
        @if (!string.IsNullOrEmpty(Model.BannerUrl))
        {
            <img src="@Model.BannerUrl" alt="@Model.Name" />
        }
        else
        {
            <div class="mv-store-hero__banner-default"></div>
        }
        <div class="mv-store-hero__overlay"></div>
    </div>
    <div class="mv-store-hero__content">
        <div class="d-flex align-items-end gap-4 flex-wrap">
            <div class="mv-store-hero__logo-wrap">
                @if (!string.IsNullOrEmpty(Model.LogoUrl))
                {
                    <img src="@Model.LogoUrl" class="mv-store-hero__logo" alt="@Model.Name" />
                }
                else
                {
                    <div class="mv-store-hero__logo mv-store-hero__logo-placeholder">
                        <i class="bi bi-shop fs-1"></i>
                    </div>
                }
            </div>
            <div class="flex-grow-1">
                <div class="mv-store-hero__badge mb-2">
                    <i class="bi bi-patch-check-fill me-1"></i>Verified Store
                </div>
                <h1 class="mv-store-hero__name">@Model.Name</h1>
                <div class="d-flex align-items-center gap-3 flex-wrap mt-1">
                    @if (!string.IsNullOrEmpty(Model.VendorBusiness))
                    {
                        <span class="mv-store-hero__meta"><i class="bi bi-building me-1"></i>@Model.VendorBusiness</span>
                    }
                    <span class="mv-store-hero__meta"><i class="bi bi-box-seam me-1"></i>@Model.ProductCount product@(Model.ProductCount == 1 ? "" : "s")</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Store info & contact -->
@if (!string.IsNullOrEmpty(Model.Description) || !string.IsNullOrEmpty(Model.ContactEmail) || !string.IsNullOrEmpty(Model.ContactPhone))
{
    <div class="mv-store-info-card mb-4">
        <div class="row g-3 align-items-center">
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="col-md-8">
                    <p class="mb-0 text-muted" style="line-height:1.7;font-size:.92rem;">@Model.Description</p>
                </div>
            }
            <div class="col-md-4 text-md-end">
                <div class="d-flex flex-column gap-2 align-items-start align-items-md-end">
                    @if (!string.IsNullOrEmpty(Model.ContactEmail))
                    {
                        <a href="mailto:@Model.ContactEmail" class="mv-store-contact">
                            <i class="bi bi-envelope-fill me-2"></i>@Model.ContactEmail
                        </a>
                    }
                    @if (!string.IsNullOrEmpty(Model.ContactPhone))
                    {
                        <a href="tel:@Model.ContactPhone" class="mv-store-contact">
                            <i class="bi bi-telephone-fill me-2"></i>@Model.ContactPhone
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
}

<!-- Products section -->
<div class="mv-section-header mb-4">
    <div>
        <h2 class="mv-section-header__title">Products from @Model.Name</h2>
        <p class="mv-section-header__sub">@products.TotalCount product@(products.TotalCount == 1 ? "" : "s") available</p>
    </div>
    <a asp-controller="Products" asp-action="Index" class="mv-section-header__link">
        All products <i class="bi bi-arrow-right ms-1"></i>
    </a>
</div>

@if (!products.Items.Any())
{
    <div class="mv-empty-state text-center py-5">
        <div class="mv-empty-state__icon mx-auto mb-3"><i class="bi bi-box2"></i></div>
        <h5 class="fw-bold">No products yet</h5>
        <p class="text-muted small">This store hasn't published any products yet. Check back soon!</p>
    </div>
}
else
{
    <div class="row g-3 g-lg-4">
        @foreach (var p in products.Items)
        {
            <div class="col-md-6 col-xl-4 mv-animate-rise">
                <partial name="_ProductCard" model="p" />
            </div>
        }
    </div>

    @if (products.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination mv-pagination justify-content-center">
                @for (int page = 1; page <= products.TotalPages; page++)
                {
                    <li class="page-item @(page == products.PageNumber ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-slug="@Model.Slug" asp-route-page="@(page)">@(page)</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
