@using Domain.Enums
@model Application.Common.Models.PaginatedList<Application.Products.Queries.GetProductsForAdmin.AdminProductListItemDto>
@{
    ViewData["Title"] = "Products approval";
    var filter       = ViewBag.Filter as ProductApprovalStatus?;
    var search       = ViewBag.Search as string;
    var categoryId   = ViewBag.CategoryId as Guid?;
    var vendorSearch = ViewBag.VendorSearch as string;
    var categories   = ViewBag.Categories as IEnumerable<Application.Categories.Queries.GetCategoryLookup.CategoryLookupDto>
                       ?? Enumerable.Empty<Application.Categories.Queries.GetCategoryLookup.CategoryLookupDto>();

    var route = new Dictionary<string, string?>();
    if (filter.HasValue)                         route["status"]       = filter.Value.ToString();
    if (!string.IsNullOrWhiteSpace(search))      route["search"]       = search;
    if (categoryId.HasValue)                     route["categoryId"]   = categoryId.Value.ToString();
    if (!string.IsNullOrWhiteSpace(vendorSearch)) route["vendorSearch"] = vendorSearch;
}

<div class="mv-list">
    <div class="card shadow-sm mb-3">
        <form method="get">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Product name</label>
                        <input name="search" value="@search" class="form-control" placeholder="Product name…" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Vendor / store</label>
                        <input name="vendorSearch" value="@vendorSearch" class="form-control" placeholder="Vendor / store name…" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All categories</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id" selected="@(categoryId == c.Id)">@c.Name</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Approval status</label>
                        <select name="status" class="form-select">
                            <option value="" selected="@(filter is null)">All statuses</option>
                            <option value="Pending"  selected="@(filter == ProductApprovalStatus.Pending)">Pending</option>
                            <option value="Approved" selected="@(filter == ProductApprovalStatus.Approved)">Approved</option>
                            <option value="Rejected" selected="@(filter == ProductApprovalStatus.Rejected)">Rejected</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="card-footer text-end">
                @if (route.Any())
                {
                    <a asp-action="Index" class="btn btn-secondary me-1">Clear</a>
                }
                <button class="btn btn-primary"><i class="bi bi-funnel me-1"></i>Filter</button>
            </div>
        </form>
    </div>

    <div class="card shadow-sm">
        @if (!Model.Items.Any())
        {
            <div class="card-body">
                <div class="mv-empty">
                    <div class="mv-empty-icon"><i class="bi bi-box-seam"></i></div>
                    <h6>No products match</h6>
                    <p class="text-muted small mb-0">Try different filters.</p>
                </div>
            </div>
        }
        else
        {
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="mv-list-table table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="width:64px"></th>
                                <th>Product</th>
                                <th>Vendor / Store</th>
                                <th>Category</th>
                                <th class="text-end">Base price</th>
                                <th class="text-center">Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var p in Model.Items)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(p.MainImageUrl))
                                    { <img src="@p.MainImageUrl" class="rounded" style="width:48px;height:48px;object-fit:cover" /> }
                                    else
                                    { <div class="rounded bg-body-secondary text-center" style="width:48px;height:48px;line-height:48px"><i class="bi bi-image"></i></div> }
                                </td>
                                <td><strong>@p.Name</strong><br /><small class="text-muted"><code>@p.Slug</code></small></td>
                                <td>@p.VendorBusiness<br /><small class="text-muted">@p.StoreName</small></td>
                                <td>@p.CategoryName</td>
                                <td class="text-end fw-semibold">@p.BasePrice.ToString("0.00")</td>
                                <td class="text-center">
                                    @switch (p.ApprovalStatus)
                                    {
                                        case ProductApprovalStatus.Approved: <span class="mv-pill mv-pill-approved"><i class="bi bi-check-circle"></i>Approved</span> break;
                                        case ProductApprovalStatus.Pending:  <span class="mv-pill mv-pill-pending"><i class="bi bi-hourglass-split"></i>Pending</span> break;
                                        case ProductApprovalStatus.Rejected: <span class="mv-pill mv-pill-rejected"><i class="bi bi-x-circle"></i>Rejected</span> break;
                                    }
                                </td>
                                <td class="text-end">
                                    <a asp-action="Details" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary"><i class="bi bi-eye me-1"></i>Review</a>
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer">
                @await Html.PartialAsync("_Pagination", (Model.PageNumber, Model.TotalPages, Model.TotalCount, Model.HasPrevious, Model.HasNext, route))
            </div>
        }
    </div>
</div>
