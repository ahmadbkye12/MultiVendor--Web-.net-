@model Application.Categories.Queries.GetCategoryById.CategoryDetailDto
@{
    ViewData["Title"] = $"Delete — {Model.Name}";
}

<div class="card border-danger shadow-sm">
    <div class="card-header bg-danger text-white"><i class="bi bi-exclamation-triangle me-1"></i>Confirm deletion</div>
    <div class="card-body">
        <p>You're about to delete the category <strong>@Model.Name</strong>. This action cannot be undone.</p>
        <ul class="text-muted small mb-0">
            <li>Slug: <code>@Model.Slug</code></li>
            <li>Products in this category: @Model.ProductCount</li>
        </ul>
    </div>
    <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
        <div class="card-footer text-end">
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-danger"><i class="bi bi-trash me-1"></i>Delete</button>
        </div>
    </form>
</div>
