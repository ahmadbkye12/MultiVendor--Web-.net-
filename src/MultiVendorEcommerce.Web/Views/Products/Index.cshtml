@model Application.Common.Models.PaginatedList<Application.Products.Queries.GetPublicProducts.PublicProductCardDto>
@{
    ViewData["Title"] = "Products";
    var cats = ViewBag.Categories as List<Application.Categories.Queries.GetCategoryLookup.CategoryLookupDto>;
    var search = ViewBag.Search as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var catId = ViewBag.CategoryId as Guid?;
}

<div class="mv-page-hero mb-4">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <h2 class="mb-2"><i class="bi bi-grid me-2"></i>Products</h2>
            <p class="lead mb-0 small">@Model.TotalCount product@(Model.TotalCount == 1 ? "" : "s") found — shop the marketplace in one place.</p>
        </div>
        <div class="col-lg-4 d-none d-lg-flex justify-content-end">
            <i class="bi bi-bag-check" style="font-size:4.5rem;opacity:.2"></i>
        </div>
    </div>
</div>

<div class="row g-4 g-xl-5">
    <aside class="col-lg-3">
        <div class="card mv-card mv-filter-panel border-0" style="position:sticky; top:5.5rem;">
            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Search</label>
                        <input type="text" name="search" value="@search" class="form-control" placeholder="Find a product..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All categories</option>
                            @if (cats is not null)
                            {
                                foreach (var c in cats)
                                {
                                    <option value="@c.Id" selected="@(catId == c.Id)">@c.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <label class="form-label small fw-semibold">Price range</label>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <input type="number" step="0.01" min="0" name="minPrice" value="@(minPrice?.ToString("0.##"))" class="form-control" placeholder="Min" />
                        </div>
                        <div class="col">
                            <input type="number" step="0.01" min="0" name="maxPrice" value="@(maxPrice?.ToString("0.##"))" class="form-control" placeholder="Max" />
                        </div>
                    </div>
                    <button class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Apply filters</button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2 small">Reset</a>
                </form>
            </div>
        </div>
    </aside>

    <div class="col-lg-9">
        @if (!Model.Items.Any())
        {
            <div class="mv-empty card border-0 shadow-sm">
                <div class="card-body py-5">
                    <div class="mv-empty-icon mx-auto"><i class="bi bi-search"></i></div>
                    <p class="mb-0 fw-semibold text-dark">No products match your filters.</p>
                    <p class="small text-muted mb-3">Try widening your search or clearing filters.</p>
                    <a asp-action="Index" class="btn btn-primary">Clear filters</a>
                </div>
            </div>
        }
        else
        {
            <div class="row g-3 g-lg-4">
                @foreach (var p in Model.Items)
                {
                    <div class="col-md-6 col-xl-4">
                        <partial name="_ProductCard" model="p" />
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-5" aria-label="Product pages">
                    <ul class="pagination mv-pagination justify-content-center flex-wrap mb-0">
                        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.PageNumber - 1)" asp-route-search="@search" asp-route-categoryId="@catId" asp-route-minPrice="@minPrice" asp-route-maxPrice="@maxPrice">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-route-page="@i" asp-route-search="@search" asp-route-categoryId="@catId" asp-route-minPrice="@minPrice" asp-route-maxPrice="@maxPrice">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.HasNext ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.PageNumber + 1)" asp-route-search="@search" asp-route-categoryId="@catId" asp-route-minPrice="@minPrice" asp-route-maxPrice="@maxPrice">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>
