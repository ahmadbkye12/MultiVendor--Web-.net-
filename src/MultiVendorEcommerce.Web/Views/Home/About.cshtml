@{
    ViewData["Title"] = "About us";
}

<section class="mv-hero mb-5">
    <div class="row align-items-center">
        <div class="col-lg-7">
            <span class="badge bg-light text-primary mb-3">About</span>
            <h1 class="display-5 mb-3">A marketplace for everyone</h1>
            <p class="lead mb-0">We connect independent vendors with customers in one trusted, friendly storefront.</p>
        </div>
        <div class="col-lg-5 d-none d-lg-block text-end">
            <i class="bi bi-people-fill" style="font-size:10rem; opacity:.18; color:#fff;"></i>
        </div>
    </div>
</section>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="card mv-card h-100 text-center">
            <div class="card-body">
                <div class="mv-cat-icon mx-auto mb-3"><i class="bi bi-bullseye"></i></div>
                <h5>Our mission</h5>
                <p class="text-muted small mb-0">Make it easy for small vendors to reach customers without giving up their identity.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mv-card h-100 text-center">
            <div class="card-body">
                <div class="mv-cat-icon mx-auto mb-3"><i class="bi bi-eye"></i></div>
                <h5>Our vision</h5>
                <p class="text-muted small mb-0">A marketplace where curated, independent stores thrive alongside one another.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card mv-card h-100 text-center">
            <div class="card-body">
                <div class="mv-cat-icon mx-auto mb-3"><i class="bi bi-heart"></i></div>
                <h5>Our values</h5>
                <p class="text-muted small mb-0">Transparency, fair commission, and a customer-first checkout experience.</p>
            </div>
        </div>
    </div>
</div>

<div class="card mv-card mb-5">
    <div class="card-body p-4 p-md-5">
        <h3 class="mb-3">Our story</h3>
        <p>This marketplace exists to give small businesses a place where they keep their brand, manage their own products, and reach a wider audience — without the friction of building a full e-commerce stack themselves.</p>
        <p>Customers get the variety of many shops with the convenience of one cart, one checkout, and consistent fulfillment tracking — even when their order spans multiple vendors.</p>
        <p class="mb-0">Behind the scenes, vendors keep full control of their store profile, products, variants, prices, coupons, and order fulfillment, while we handle the platform plumbing: discoverability, payments, refunds, and trust.</p>
    </div>
</div>

<div class="row g-3 text-center mb-4">
    <div class="col-md-3 col-6">
        <div class="card mv-card">
            <div class="card-body">
                <h2 class="mv-price mb-0" style="font-size:2rem;">2+</h2>
                <small class="text-muted">Vendor stores</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card mv-card">
            <div class="card-body">
                <h2 class="mv-price mb-0" style="font-size:2rem;">10+</h2>
                <small class="text-muted">Curated products</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card mv-card">
            <div class="card-body">
                <h2 class="mv-price mb-0" style="font-size:2rem;">5</h2>
                <small class="text-muted">Categories</small>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card mv-card">
            <div class="card-body">
                <h2 class="mv-price mb-0" style="font-size:2rem;">100%</h2>
                <small class="text-muted">Independent</small>
            </div>
        </div>
    </div>
</div>
