@model List<Application.Addresses.Queries.GetMyAddresses.AddressDto>
@{
    ViewData["Title"] = "Addresses";
}

<div class="mv-section-head mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-geo-alt me-2"></i>My Addresses</h2>
        <small class="text-muted">@Model.Count saved address@(Model.Count == 1 ? "" : "es")</small>
    </div>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Add address</a>
</div>

@if (!Model.Any())
{
    <div class="card mv-card">
        <div class="card-body text-center py-5">
            <i class="bi bi-geo-alt display-3 d-block mb-3 text-muted"></i>
            <h5>No addresses yet</h5>
            <p class="text-muted">You'll need at least one address to check out.</p>
            <a asp-action="Create" class="btn btn-primary mt-2"><i class="bi bi-plus-lg me-1"></i>Add your first address</a>
        </div>
    </div>
}
else
{
    <div class="row g-3">
    @foreach (var a in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card mv-card h-100 @(a.IsDefault ? "border-primary" : "")">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div class="mv-cat-icon" style="width:40px;height:40px;font-size:1.1rem;"><i class="bi bi-house-door"></i></div>
                        @if (a.IsDefault) { <span class="badge bg-primary"><i class="bi bi-star-fill me-1"></i>Default</span> }
                    </div>
                    <h6 class="card-title fw-bold">@(a.Label ?? "Address")</h6>
                    <p class="small text-muted mb-1">@a.Line1</p>
                    @if (!string.IsNullOrEmpty(a.Line2)) { <p class="small text-muted mb-1">@a.Line2</p> }
                    <p class="small text-muted mb-1">@a.City@(string.IsNullOrEmpty(a.State) ? "" : $", {a.State}") @a.PostalCode</p>
                    <p class="small text-muted mb-1">@a.Country</p>
                    @if (!string.IsNullOrEmpty(a.Phone)) { <p class="small text-muted mb-0"><i class="bi bi-telephone me-1"></i>@a.Phone</p> }
                </div>
                <div class="card-footer bg-white border-0 pb-3 d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-sm btn-outline-primary flex-grow-1"><i class="bi bi-pencil me-1"></i>Edit</a>
                    <form asp-action="Delete" asp-route-id="@a.Id" method="post" onsubmit="return confirm('Delete this address?');">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </div>
            </div>
        </div>
    }
    </div>
}
