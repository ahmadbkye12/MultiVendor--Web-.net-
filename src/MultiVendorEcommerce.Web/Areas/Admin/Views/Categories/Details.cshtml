@model Application.Categories.Queries.GetCategoryById.CategoryDetailDto
@{
    ViewData["Title"] = $"Category — {Model.Name}";
}

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Name</dt>           <dd class="col-sm-9">@Model.Name</dd>
            <dt class="col-sm-3">Slug</dt>           <dd class="col-sm-9"><code>@Model.Slug</code></dd>
            <dt class="col-sm-3">Description</dt>    <dd class="col-sm-9">@(Model.Description ?? "—")</dd>
            <dt class="col-sm-3">Parent</dt>         <dd class="col-sm-9">@(Model.ParentName ?? "Top-level")</dd>
            <dt class="col-sm-3">Icon URL</dt>       <dd class="col-sm-9">@(Model.IconUrl ?? "—")</dd>
            <dt class="col-sm-3">Display order</dt>  <dd class="col-sm-9">@Model.DisplayOrder</dd>
            <dt class="col-sm-3">Active</dt>         <dd class="col-sm-9">@(Model.IsActive ? "Yes" : "No")</dd>
            <dt class="col-sm-3">Products</dt>       <dd class="col-sm-9">@Model.ProductCount</dd>
            <dt class="col-sm-3">Created</dt>        <dd class="col-sm-9">@Model.CreatedAtUtc.ToString("u")</dd>
            <dt class="col-sm-3">Updated</dt>        <dd class="col-sm-9">@(Model.UpdatedAtUtc?.ToString("u") ?? "—")</dd>
        </dl>
    </div>
    <div class="card-footer text-end">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-1"></i>Edit</a>
    </div>
</div>
