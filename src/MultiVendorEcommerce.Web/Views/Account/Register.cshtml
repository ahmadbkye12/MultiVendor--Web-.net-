@model Web.Models.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<h2 class="mb-1 fw-bold">Create your account</h2>
<p class="text-muted mb-4">Start shopping in minutes — it's free.</p>

<form asp-action="Register" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

    <div class="mb-3">
        <label asp-for="FullName" class="form-label small fw-semibold"></label>
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-person"></i></span>
            <input asp-for="FullName" class="form-control border-start-0 ps-0" placeholder="Jane Doe" />
        </div>
        <span asp-validation-for="FullName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label small fw-semibold"></label>
        <div class="input-group">
            <span class="input-group-text bg-white"><i class="bi bi-envelope"></i></span>
            <input asp-for="Email" type="email" class="form-control border-start-0 ps-0" placeholder="you@example.com" />
        </div>
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="row g-2">
        <div class="col-md-6 mb-3">
            <label asp-for="Password" class="form-label small fw-semibold"></label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="Password" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
            </div>
            <span asp-validation-for="Password" class="text-danger small"></span>
        </div>
        <div class="col-md-6 mb-3">
            <label asp-for="ConfirmPassword" class="form-label small fw-semibold"></label>
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-lock-fill"></i></span>
                <input asp-for="ConfirmPassword" type="password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
            </div>
            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
        </div>
    </div>

    <p class="small text-muted mb-3">By registering you agree to our <a asp-controller="Home" asp-action="Terms">Terms</a> and <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>.</p>

    <button type="submit" class="btn btn-primary btn-lg w-100"><i class="bi bi-person-plus me-1"></i>Create account</button>
</form>

<p class="text-center text-muted small mt-3 mb-0">Already have an account? <a asp-action="Login">Sign in</a></p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
