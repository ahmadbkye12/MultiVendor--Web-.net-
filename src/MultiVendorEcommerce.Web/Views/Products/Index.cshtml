@model Application.Common.Models.PaginatedList<Application.Products.Queries.GetPublicProducts.PublicProductCardDto>
@{
    ViewData["Title"] = "Products";
    var cats = ViewBag.Categories as List<Application.Categories.Queries.GetCategoryLookup.CategoryLookupDto>;
    var search = ViewBag.Search as string;
    var minPrice = ViewBag.MinPrice as decimal?;
    var maxPrice = ViewBag.MaxPrice as decimal?;
    var catId = ViewBag.CategoryId as Guid?;
}

<div class="mv-section-head mb-3">
    <div>
        <h2 class="mb-0"><i class="bi bi-grid me-2"></i>Products</h2>
        <small class="text-muted">@Model.TotalCount product@(Model.TotalCount == 1 ? "" : "s") found</small>
    </div>
</div>

<div class="row g-4">
    <aside class="col-lg-3">
        <div class="card mv-card" style="position:sticky; top:1rem;">
            <div class="card-header bg-white border-0 pt-3">
                <h6 class="mb-0"><i class="bi bi-funnel me-2"></i>Filter</h6>
            </div>
            <div class="card-body">
                <form method="get">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Search</label>
                        <input type="text" name="search" value="@search" class="form-control" placeholder="Find a product..." />
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Category</label>
                        <select name="categoryId" class="form-select">
                            <option value="">All categories</option>
                            @if (cats is not null)
                            {
                                foreach (var c in cats)
                                {
                                    <option value="@c.Id" selected="@(catId == c.Id)">@c.Name</option>
                                }
                            }
                        </select>
                    </div>
                    <label class="form-label small fw-semibold">Price range</label>
                    <div class="row g-2 mb-3">
                        <div class="col">
                            <input type="number" step="0.01" min="0" name="minPrice" value="@(minPrice?.ToString("0.##"))" class="form-control" placeholder="Min" />
                        </div>
                        <div class="col">
                            <input type="number" step="0.01" min="0" name="maxPrice" value="@(maxPrice?.ToString("0.##"))" class="form-control" placeholder="Max" />
                        </div>
                    </div>
                    <button class="btn btn-primary w-100"><i class="bi bi-funnel me-1"></i>Apply filters</button>
                    <a asp-action="Index" class="btn btn-link w-100 mt-2 small">Reset</a>
                </form>
            </div>
        </div>
    </aside>

    <div class="col-lg-9">
        @if (!Model.Items.Any())
        {
            <div class="alert alert-info text-center py-5">
                <i class="bi bi-search display-4 d-block mb-2"></i>
                No products match your filters. <a asp-action="Index">Clear filters</a> and try again.
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var p in Model.Items)
                {
                    var hasDiscount = p.MinVariantPrice.HasValue && p.MinVariantPrice < p.BasePrice;
                    <div class="col-md-4 col-sm-6">
                        <div class="card mv-card h-100 position-relative">
                            @if (hasDiscount) { <span class="mv-badge-sale">SALE</span> }
                            <a asp-action="Details" asp-route-slug="@p.Slug" class="text-decoration-none text-reset">
                                <div class="mv-img-wrap">
                                    @if (!string.IsNullOrEmpty(p.MainImageUrl))
                                    { <img src="@p.MainImageUrl" class="card-img-top" style="height:200px;object-fit:cover" /> }
                                    else
                                    { <div class="card-img-top bg-body-secondary d-flex justify-content-center align-items-center" style="height:200px"><i class="bi bi-image display-4 text-muted"></i></div> }
                                </div>
                                <div class="card-body">
                                    <div class="text-muted small text-uppercase">@p.CategoryName</div>
                                    <h6 class="card-title mt-1 mb-1">@p.Name</h6>
                                    <a asp-controller="Stores" asp-action="Index" asp-route-slug="@p.StoreSlug" class="mv-store-link" onclick="event.stopPropagation();"><i class="bi bi-shop me-1"></i>@p.StoreName</a>
                                    <div class="mt-2 d-flex align-items-baseline">
                                        <span class="mv-price">@((p.MinVariantPrice ?? p.BasePrice).ToString("0.00"))</span>
                                        @if (hasDiscount) { <span class="mv-price-old">@p.BasePrice.ToString("0.00")</span> }
                                    </div>
                                    @if (p.ReviewCount > 0)
                                    {
                                        <div class="mt-1">
                                            <span class="mv-rating"><i class="bi bi-star-fill"></i> @p.AverageRating.ToString("0.0")</span>
                                            <small class="text-muted">(@p.ReviewCount)</small>
                                        </div>
                                    }
                                </div>
                            </a>
                        </div>
                    </div>
                }
            </div>

            @if (Model.TotalPages > 1)
            {
                <nav class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item @(Model.HasPrevious ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.PageNumber - 1)" asp-route-search="@search" asp-route-categoryId="@catId">Previous</a>
                        </li>
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-route-page="@i" asp-route-search="@search" asp-route-categoryId="@catId">@i</a>
                            </li>
                        }
                        <li class="page-item @(Model.HasNext ? "" : "disabled")">
                            <a class="page-link" asp-route-page="@(Model.PageNumber + 1)" asp-route-search="@search" asp-route-categoryId="@catId">Next</a>
                        </li>
                    </ul>
                </nav>
            }
        }
    </div>
</div>
