@model Web.Models.ViewModels.Addresses.AddressFormViewModel
@{
    ViewData["Title"] = "Edit address";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Addresses</a></li>
        <li class="breadcrumb-item active">Edit address</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6">
        <div style="background:#fff;border-radius:1.15rem;border:1px solid rgba(99,102,241,.12);box-shadow:0 4px 24px rgba(0,0,0,.07);overflow:hidden;">
            <div style="height:4px;background:var(--mv-grad-1);"></div>
            <div class="p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div style="width:46px;height:46px;border-radius:.75rem;background:var(--mv-grad-soft);
                                display:flex;align-items:center;justify-content:center;color:#6366f1;font-size:1.25rem;">
                        <i class="bi bi-pencil-square"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0" style="color:#0f172a;letter-spacing:-.01em;">Edit address</h4>
                        <small class="text-muted">Update your shipping details</small>
                    </div>
                </div>
                <form asp-action="Edit" method="post">
                    <partial name="_Form" model="Model" />
                    <div class="d-flex justify-content-between gap-2 mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                        <button class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-1"></i>Save changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { <partial name="_ValidationScriptsPartial" /> }
